graph TB
    subgraph Client_Zone ["Giao diện Người dùng"]
        CLI["KBMS.CLI"]
        Studio["KBMS Studio"]
    end

    subgraph Server_Layer ["Chapter 4.6: Kiến trúc Tầng Server"]
        subgraph Network_Module ["4.6.2 Network & Session"]
            CM["ConnectionManager"]
