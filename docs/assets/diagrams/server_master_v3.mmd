    %% Flow
    CLI --> Protocol
    Studio --> Protocol
    Protocol --> CM
    CM --> Session
    Session --> Lexer
    Lexer --> Parser
    Parser --> AST
    AST --> Auth
    Auth --> KM
    KM --> Router
    Router --> SP
    SP --> WAL
    
