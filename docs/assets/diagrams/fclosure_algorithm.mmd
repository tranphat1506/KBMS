graph TD
    Start["Bắt đầu: Fact Insertion"] --> Compile["Biên dịch Topology (Rete Compiler)"]
    Compile --> Prop["Lan truyền Token Gia tăng (Incremental Prop)"]
    
    subgraph Network_Matching["Cơ chế So khớp Mạng lưới"]
        Prop --> Alpha["Lọc Thuộc tính (Alpha Node)"]
        Alpha --> Beta["So khớp Liên hợp (Beta Join)"]
        Beta --> Terminal["Kích hoạt Luật (Activation)"]
    end
    
    Terminal --> Agenda["Quản lý Bộ đệm Agenda"]
    Agenda -- "FireNext" --> Exec["Thực thi Luật / Giải phương trình"]
    
    Exec -- "Sinh Fact mới" --> Prop
    Agenda -- "Agenda Rỗng" --> Stop["Điểm dừng (Fixed-point Closure)"]
    
    Stop --> End["Kết thúc: ReasoningResult"]
