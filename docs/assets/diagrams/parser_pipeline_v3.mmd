graph TD
    Input["Chuỗi KBQL (Raw String)"]
    
    subgraph Lexing ["Giai đoạn 1: Phân tích Từ vựng (Lexer)"]
        Scanner["Scanner (Char by Char)"]
        TokenGen["Kiểm tra Từ khóa & Hằng số"]
        Tokens["Danh sách Tokens (Stream)"]
    end

    subgraph Parsing ["Giai đoạn 2: Phân tích Cú pháp (Parser)"]
        RD["Trình phân tích Đệ quy Xuống (Recursive Descent)"]
        Rules["Ngữ pháp KBQL (Grammar Rules)"]
    end

    subgraph AST_Module ["Giai đoạn 3: Cấu trúc AST (Abstract Syntax Tree)"]
        AstNode["AstNode (Base Class)"]
        Kql["KQLNode (Select/Insert)"]
        Kdl["KDLNode (Create/Drop)"]
        Kcl["KCLNode (User/Grant)"]
    end

    %% Flow
    Input --> Scanner
    Scanner --> TokenGen
    TokenGen --> Tokens
    Tokens --> RD
    Rules -.-> RD
    RD --> AstNode
    AstNode --> Kql
    AstNode --> Kdl
    AstNode --> Kcl
    
    %% Styling
    style Lexing fill:#e6f7ff,stroke:#1890ff
    style Parsing fill:#fff7e6,stroke:#ffa940
    style AST_Module fill:#f6ffed,stroke:#52c41a
    style Input fill:#fff,stroke:#333,stroke-width:2px
