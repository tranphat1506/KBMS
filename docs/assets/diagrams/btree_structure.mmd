graph TD
    subgraph "KBMS B+ Tree Indexing (4-way)"
        direction TB

        subgraph "Internal Level (Routing)"
            Root["<b>ROOT NODE (Page 10)</b><br/>[K: 50 | K: 100]"]
            I1["Internal Node (Page 15)<br/>[K: 20 | K: 40]"]
            I2["Internal Node (Page 16)<br/>[K: 70 | K: 90]"]
            I3["Internal Node (Page 17)<br/>[K: 120 | K: 140]"]
        end

        subgraph "Leaf Level (Data Storage)"
            L1["Leaf Node (Page 20)<br/>[1...19]"]
            L2["Leaf Node (Page 21)<br/>[20...39]"]
            L3["Leaf Node (Page 22)<br/>[40...49]"]
            L4["Leaf Node (Page 23)<br/>[50...69]"]
        end

        %% Routing Links
        Root --> I1
        Root --> I2
        Root --> I3
        
        I1 --> L1
        I1 --> L2
        I1 --> L3
        I2 --> L4

        %% Sibling Pointers (Linked List)
        L1 <--> L2
        L2 <--> L3
        L3 <--> L4
    end

    %% Styling
    style Root fill:#e1f5fe,stroke:#01579b,stroke-width:2px
    style I1 fill:#f5f5f5,stroke:#616161
    style I2 fill:#f5f5f5,stroke:#616161
    style I3 fill:#f5f5f5,stroke:#616161
    style L1 fill:#fff9c4,stroke:#fbc02d
    style L2 fill:#fff9c4,stroke:#fbc02d
    style L3 fill:#fff9c4,stroke:#fbc02d
    style L4 fill:#fff9c4,stroke:#fbc02d

    classDef leaf font-weight:bold,color:#5d4037
    class L1,L2,L3,L4 leaf
