graph TD
    subgraph App_Layer ["Tầng 1: Application (UI)"]
        React["React Components / Redux"]
        Monaco["Monaco Editor (KQL/KDL)"]
        Dash["Management Dashboard"]
    end
    
    subgraph Network_Layer ["Tầng 2: Network (Socket)"]
        Socket["Socket Client (Electron Main)"]
        Binary["Binary Protocol (Header/Payload)"]
    end
    
    subgraph Server_Layer ["Tầng 3: Server (Engine)"]
        Orch["Orchestration (KnowledgeManager)"]
        RE["Reasoning Engine (F-Closure)"]
        Audit["Audit & Session Logs"]
    end
    
    subgraph Storage_Layer ["Tầng 4: Storage (Data)"]
        BTree["B+ Tree Indexing"]
        LRU["Page Cache (LRU Manager)"]
        WAL["WAL (Durability)"]
    end
    
    React --- Socket
    Socket <==> Binary
    Binary <==> Orch
    Orch --- RE
    Orch --- Audit
    Orch --- BTree
    BTree --- LRU
    LRU --- WAL
    
    style App_Layer fill:#f0f7ff,stroke:#0050b3
    style Network_Layer fill:#fff7e6,stroke:#d46b08
