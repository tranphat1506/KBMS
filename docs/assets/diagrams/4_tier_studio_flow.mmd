graph TD
    subgraph UI_Layer ["Tầng 1: Application UI (React/Electron)"]
        React["React Components (Redux Store)"]
        Monaco["Monaco Editor (KQL/KDL Logic)"]
    end
    
    subgraph Net_Layer ["Tầng 2: Network & Protocol (Binary)"]
        Socket["Electron Main (Socket Client)"]
        Binary["Binary Framing (Header/Payload)"]
    end
    
    subgraph Eng_Layer ["Tầng 3: Knowledge Engine (Server)"]
        Orch["KnowledgeManager (Orchestrator)"]
        Reason["Reasoning Engine (F-Closure)"]
        Audit["Audit & Session Telemetry"]
    end
    
    subgraph Store_Layer ["Tầng 4: Storage & Persistence (Data)"]
        BTree["B+ Tree Indexing"]
        LRU["Buffer Pool (LRU Manager)"]
        WAL["WAL (Write-Ahead Logging)"]
    end
    
    %% Connections
    React --> Socket
    Monaco --> Socket
    Socket <==> Binary
    Binary <==> Orch
    Orch <==> Reason
    Orch --> Audit
    Orch <==> BTree
    BTree <==> LRU
    LRU <==> WAL
    
    %% Styling
    style UI_Layer fill:#e6f7ff,stroke:#1890ff,stroke-width:2px
    style Net_Layer fill:#fff7e6,stroke:#ffa940,stroke-width:2px
    style Eng_Layer fill:#f6ffed,stroke:#52c41a,stroke-width:2px
    style Store_Layer fill:#fff1f0,stroke:#f5222d,stroke-width:2px
    
    style React fill:#fff,stroke:#1890ff
    style Monaco fill:#fff,stroke:#1890ff
    style Socket fill:#fff,stroke:#ffa940
    style Binary fill:#fff,stroke:#ffa940
    style Orch fill:#fff,stroke:#52c41a
    style Reason fill:#fff,stroke:#52c41a
    style Audit fill:#fff,stroke:#52c41a
    style BTree fill:#fff,stroke:#f5222d
    style LRU fill:#fff,stroke:#f5222d
    style WAL fill:#fff,stroke:#f5222d
