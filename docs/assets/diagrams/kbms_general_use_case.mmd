graph LR
    User([Học viên / Nghiên cứu sinh])
    Admin([Quản trị viên])
    
    subgraph AppLayer [Application Layer]
        Studio["KBMS Studio<br/>(Visual IDE)"]
        CLI["KBMS CLI<br/>(REPL)"]
    end

    subgraph ServerLayer [Server Engine Layer]
        KM["KnowledgeManager<br/>(Coordinator)"]
        RE["Reasoning Engine<br/>(Inference)"]
        KDL["Compiler<br/>(Parser/AST)"]
    end

    subgraph StorageLayer [Storage Layer]
        Index["B+ Tree Indexing"]
        BP["BufferPoolManager"]
        WAL["WalManager (ACID)"]
    end

    User --> Studio
    User --> CLI
    Admin --> Studio
    
    Studio --> KM
    CLI --> KM
    
    KM --> KDL
    KDL --> RE
    RE --> Index
    RE --> BP
    BP --> WAL

    style AppLayer fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style ServerLayer fill:#fff3e0,stroke:#ef6c00,stroke-width:2px
    style StorageLayer fill:#fce4ec,stroke:#c2185b,stroke-width:2px
