graph LR
    subgraph "Tuple Binary Layout (Record)"
        ID["Object ID (16 Bytes)"]
        Cnt["Field Count (4 Bytes)"]
        Offs["Offset Array (N x 4 Bytes)"]
        Payload["Data Payload (Variable Length)"]
        
        ID --- Cnt
        Cnt --- Offs
        Offs --- Payload
    end
