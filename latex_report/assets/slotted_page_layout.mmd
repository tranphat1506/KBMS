graph TD
    subgraph "Slotted Page Binary Structure (16,384 Bytes)"
        H["PAGE HEADER (24 Bytes)<br/>[PageId | LSN | Prev | Next | FSP | Count]"]
        SA["SLOT ARRAY (Growing Forwards)<br/>[Slot 0: {Off, Len} | Slot 1 | Slot N]"]
        FS["FREE SPACE (Available Memory)"]
        TS["TUPLE STORAGE (Growing Backwards)<br/>[Tuple N | Tuple 1 | Tuple 0]"]
        
        H --- SA
        SA --- FS
        FS --- TS
    end
