graph LR
    KDL["KDL Family"]
    
    subgraph KB_Nodes ["Cấu trúc Dữ liệu"]
        KDL --- KB["KB: Create/Drop/Use/Alter"]
        KDL --- Concept["Concept: Create/Drop/Alter/Variable"]
    end
    
    subgraph Logic_Nodes ["Đối tượng Logic"]
        KDL --- Rel["Relation / Operator / Function"]
