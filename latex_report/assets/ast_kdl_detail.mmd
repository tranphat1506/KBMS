    subgraph Adv_Nodes ["Hạ tầng & Phản ứng"]
        KDL --- H["Hierarchy / Computation"]
        KDL --- T["Trigger / Index"]
    end
    
    style KDL fill:#dfd,stroke:#333,stroke-width:4px
    style KB_Nodes,Logic_Nodes,Adv_Nodes fill:#f9fff9,stroke:#9c9,stroke-dasharray: 5 5
