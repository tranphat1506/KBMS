graph LR
    KCL_TCL["KCL & TCL Family"]
    
    subgraph Security ["Phân quyền & Bảo mật"]
        KCL_TCL --- User["User: Create/Drop/Alter"]
        KCL_TCL --- Auth["Privileges: Grant/Revoke"]
    end
    
    subgraph Transaction ["Giao dịch (ACID)"]
        KCL_TCL --- T["BEGIN / COMMIT / ROLLBACK"]
    end
    
    style KCL_TCL fill:#eee,stroke:#333,stroke-width:4px
    style Security fill:#f5f5f5,stroke:#999,stroke-dasharray: 5 5
    style Transaction fill:#fff0f0,stroke:#c99,stroke-dasharray: 5 5
