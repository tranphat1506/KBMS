graph TD
    Start([Bắt đầu SOURCE]) --> File[Đọc tệp tin .kbql]
    File --> Loop{Còn lệnh chưa chạy?}
    
    Loop -- "Còn" --> Build[Tích lũy StringBuilder đến dấu ;]
    Build --> Exec[Gửi lệnh ExecuteCommandAsync]
    Exec --> Stream[Xử lý luồng Metadata/Row]
    Stream --> Check{Có lỗi không?}
    
    Check -- "Không" --> Loop
    Check -- "Có lỗi" --> Stop[Dừng tập lệnh/Báo lỗi dòng]
    
    Loop -- "Hết" --> Stats[In thống kê thời gian thực thi]
    Stats --> End([Kết thúc])

    style Start fill:#f6ffed,stroke:#389e0d
    style End fill:#f6ffed,stroke:#389e0d
    style Check fill:#fff7e6,stroke:#d46b08
