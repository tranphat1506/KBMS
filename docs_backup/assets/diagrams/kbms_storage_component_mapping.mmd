graph TD
    subgraph RAM [Bộ nhớ RAM]
        SP[StoragePool - Singleton]
        subgraph KB_Managers [Quản lý từng KB]
            BPM[BufferPoolManager - LRU Cache]
            DM[DiskManager - I/O Handler]
            WM[WalManager - Logging]
        end
    end

    subgraph DISK [Đĩa cứng]
        DAT[Tệp dữ liệu .dat / .kdb]
        LOG[Tệp nhật ký .log]
    end

    SP -->|Khởi tạo/Truy xuất| KB_Managers
    BPM -->|Fetch/Flush Page| DM
    DM -->|Read/Write| DAT
    BPM -.->|Lập lịch ghi Log| WM
    WM -->|Append| LOG

    style SP fill:#e1f5fe,stroke:#01579b
    style KB_Managers fill:#fff3e0,stroke:#e65100
    style DISK fill:#f1f8e9,stroke:#33691e
