graph TD
    Start([Mở Log Analyzer]) --> Load[Tải 1000 dòng nhật ký gần nhất]
    Load --> Filter{Bộ lọc thông minh}
    
    Filter -- "Level" --> L[Critical / Error / Info]
    Filter -- "Concept" --> C[Lọc theo thực thể tri thức]
    Filter -- "Time" --> T[Lọc theo dòng thời gian]
    
    L & C & T --> Search[Sử dụng RegEx tìm kiếm cụm lỗi]
    Search --> Highlight[Đánh dấu vùng lỗi hệ thống]
    Highlight --> Export[Xuất báo cáo phân tích đồ họa]
    Export --> End([Kết thúc])

    style Start fill:#f6ffed,stroke:#389e0d
    style End fill:#f6ffed,stroke:#389e0d
    style Filter fill:#fff7e6,stroke:#d46b08
