graph TD
    subgraph SlottedPage [Cấu trúc Slotted Page]
        H[Header: 24 Bytes]
        SA[Slot Array: 8B per slot]
        FS[Free Space]
        T[Tuples: Variable Length]
    end

    H --> SA
    SA -->|Grows Down| FS
    T -->|Grows Up| FS

    style H fill:#e6f7ff,stroke:#1890ff
    style SA fill:#fff7e6,stroke:#faad14
    style FS fill:#f6ffed,stroke:#52c41a
    style T fill:#fff1f0,stroke:#f5222d
