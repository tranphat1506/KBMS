graph LR
    Input["Chuỗi tri thức (Source)"] -- "Scanner" --> Lexer["Lexer.cs"]
    
    subgraph Classification ["Phân loại (O(1) Lookup)"]
        Lexer --> K["Keywords"]
        Lexer --> I["Identifiers"]
        Lexer --> L["Literals"]
        Lexer --> S["Symbols"]
    end
    
    K & I & L & S --> TokenStream["Danh sách Token (List&lt;Token&gt;)"]
    
    style Lexer fill:#f9f,stroke:#333,stroke-width:2px
    style Classification fill:#f0f0f0,stroke:#999,stroke-dasharray: 5 5
