USE EnterpriseKB;

-- 3. INFERENCE ENGINE SETUP (PHASE 5 - FORWARD)
CREATE RULE HighHonor SCOPE Student IF grade >= 90 THEN SET honor = 'High';
CREATE RULE HonorToGift SCOPE Student IF honor = 'High' THEN SET gifted = true;

-- 4. INSERT & FORWARD CHAINING
INSERT INTO Student ATTRIBUTE (1, 'Alice', 95);
INSERT INTO Student ATTRIBUTE (2, 'Bob', 85);

-- Check results (Alice should be Gifted, Bob should not)
SELECT name, grade, honor, gifted FROM Student;
