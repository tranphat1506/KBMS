-- Dataset: Stress Volume
-- Description: Mẫu dữ liệu lớn để kiểm tra 1 triệu bản ghi.

CREATE KNOWLEDGE BASE StressKB;
USE StressKB;

CREATE CONCEPT BigData (
    VARIABLES (
        id: INT,
        val: STRING,
        ts: INT
    )
);

