-- ============================================================
-- KBMS COMPREHENSIVE TEST SUITE (KBQL v1.2)
-- Highlighting: Phase 5 (Forward Chaining), True Typing, and Refined KQL
-- ============================================================

-- 1. KNOWLEDGE BASE SETUP
CREATE KNOWLEDGE BASE EnterpriseKB DESCRIPTION "Automated system for student and products management";
USE EnterpriseKB;

-- 2. CONCEPT DEFINITION (PHASE 1-4)
-- Basic concept with constraints and variables
CREATE CONCEPT Student (
    VARIABLES (
        id: INT,
        name: STRING,
        grade: DECIMAL(5, 2),
        honor: STRING,
        gifted: BOOLEAN
    )
);

-- Recursive Hierarchy (IS-A)
CREATE CONCEPT Undergrad (VARIABLES(major: STRING, credits: INT));
CREATE HIERARCHY Undergrad IS_A Student;

-- 3. INFERENCE ENGINE SETUP (PHASE 5)
-- Multi-step forward chaining rules
-- Rule 1: High grade leads to High honor
CREATE RULE HighHonor 
SCOPE Student 
IF grade >= 90 
THEN SET honor = 'High';

-- Rule 2: High honor leads to Gifted status (Recursive)
CREATE RULE HonorToGift 
SCOPE Student 
IF honor = 'High' 
THEN SET gifted = true;

-- 4. DATA MANIPULATION & FORWARD CHAINING (PHASE 5/6)
-- Bulk Insert (Phase 6)
-- Observe that 'honor' and 'gifted' will be automatically computed via Forward Chaining
INSERT INTO Student ATTRIBUTE (1, 'Alice', 95);
INSERT INTO Student ATTRIBUTE (2, 'Bob', 85);
INSERT INTO Student ATTRIBUTE (3, 'Charlie', 92);

-- Verify Forward Chaining Results
SELECT name, grade, honor, gifted FROM Student;

-- Verify via WHERE Clause (Tests Parser & Quote Handling)
SELECT * FROM Student WHERE honor = 'High';

-- 5. TRUETYPING & ALIASES (PHASE 2)
CREATE CONCEPT Product (VARIABLES(id: INT, price: DECIMAL, stock: INT));
INSERT INTO Product ATTRIBUTE (501, 1000.0, 50);

-- Complex expressions and Column Aliases
SELECT 
    p.id AS ProductID, 
    p.price * 1.1 AS PriceWithVAT,
    p.stock - 1 AS ForecastStock
FROM Product p 
WHERE p.price > 500;

-- 6. METADATA & VIRTUAL TABLES (PHASE 3/4)
-- Querying system metadata
SELECT * FROM Student.variables;
SELECT * FROM Student.rules;

-- Querying virtual tables (Phase 3)
-- This evaluates rules as if they were tables
SELECT * FROM RULE HighHonor;

-- 7. UPDATE & FORWARD CHAINING
-- Updating a student's grade should trigger re-evaluation?
-- (Current implementation triggers on INSERT/UPDATE)
UPDATE Student ATTRIBUTE ( SET grade: 98 ) WHERE name = 'Bob';

-- Bob should now have honor='High' and gifted=true
SELECT * FROM Student WHERE name = 'Bob';

-- 8. KML & ADMINISTRATION
DESCRIBE (CONCEPT: Student);
DESCRIBE (HIERARCHY: 'Student:Undergrad');
EXPLAIN (SELECT * FROM Student WHERE grade > 90);

-- SHOW Commands
SHOW CONCEPTS IN EnterpriseKB;
SHOW RULES TYPE inference;

-- 9. CLEANUP
-- DROP KNOWLEDGE BASE EnterpriseKB;

-- ============================================================
-- END OF TEST SUITE
-- ============================================================
