-- ============================================================
-- KBMS COMPREHENSIVE TEST SUITE (KBQL v1.5)
-- Features: CALC(), Advanced Math, Joins, Forward Chaining, Metadata
-- ============================================================

-- 1. KNOWLEDGE BASE SETUP
-- We drop the KB to ensure a clean state for the test suite.
DROP KNOWLEDGE BASE EnterpriseKB; 
CREATE KNOWLEDGE BASE EnterpriseKB DESCRIPTION "Automated system for student and products management";
USE EnterpriseKB;

-- 2. CONCEPT DEFINITION
CREATE CONCEPT Dept (VARIABLES(id: INT, name: STRING, budget: DECIMAL));
CREATE CONCEPT Emp (VARIABLES(id: INT, name: STRING, dept_id: INT, salary: DECIMAL, bonus_rate: DECIMAL));

CREATE CONCEPT Product (
    VARIABLES (
        id: INT,
        name: STRING,
        price: DECIMAL,
        stock: INT,
        category: STRING
    )
);

-- 3. INFERENCE ENGINE SETUP
-- Rule: Salary + Bonus calculation
CREATE RULE CalcTotalComp
SCOPE Emp
IF salary > 0
THEN SET salary = salary * (1 + bonus_rate);

-- 4. DATA INSERTION
INSERT INTO Dept ATTRIBUTE (1, 'Engineering', 1000000);
INSERT INTO Dept ATTRIBUTE (2, 'Marketing', 500000);

INSERT INTO Emp ATTRIBUTE (101, 'Alice', 1, 80000, 0.1);
INSERT INTO Emp ATTRIBUTE (102, 'Bob', 1, 75000, 0.05);
INSERT INTO Emp ATTRIBUTE (103, 'Charlie', 2, 60000, 0.15);

INSERT INTO Product ATTRIBUTE (501, 'Laptop', 1200.0, 10, 'Electronics');
INSERT INTO Product ATTRIBUTE (502, 'Monitor', 300.0, 25, 'Electronics');
INSERT INTO Product ATTRIBUTE (503, 'Chair', 150.0, 100, 'Furniture');

-- 5. ADVANCED QUERIES (The New Features)

-- A. CALC() and Complex Expressions
SELECT 
    p.name, 
    p.price, 
    CALC(p.price * 1.1) AS PriceWithTax,
    CALC(p.price * p.stock) AS InventoryValue,
    100 + 200 AS ConstantTest
FROM Product p;

-- B. Joins with Shorthand Aliases
SELECT 
    e.name AS EmployeeName, 
    d.name AS DepartmentName,
    CALC(e.salary / d.budget * 100) AS BudgetPercentage
FROM Emp e 
JOIN Dept d ON e.dept_id = d.id
WHERE e.salary > 70000;

-- C. Standalone Expressions (Literals at start)
SELECT 1.1 * 2.2 AS MathResult FROM Product LIMIT 1;

-- D. Nested CALC and Functions
SELECT 
    name, 
    price, 
    CALC(Sqrt(price) * 10) AS WeightedPrice
FROM Product 
WHERE category = 'Electronics';

-- 6. METADATA & SYSTEM QUERIES
SELECT * FROM Product.variables;
SHOW CONCEPTS IN EnterpriseKB;

-- 7. UPDATE & RE-EVALUATION
UPDATE Emp ATTRIBUTE (SET bonus_rate: 0.2) WHERE name = 'Alice';

-- Verify Alice's salary was re-calculated via Rule (Forward Chaining)
SELECT name, salary FROM Emp WHERE name = 'Alice';

-- 8. MAINTENANCE & DESCRIPTION
DESCRIBE (CONCEPT: Emp);
EXPLAIN (SELECT * FROM Emp e JOIN Dept d ON e.dept_id = d.id);

-- 9. CLEANUP (Optional)
-- DROP KNOWLEDGE BASE EnterpriseKB;

-- ============================================================
-- END OF TEST SUITE v1.5
-- ============================================================
